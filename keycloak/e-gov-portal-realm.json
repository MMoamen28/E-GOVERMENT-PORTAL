{
  "id": "e-gov-portal",
  "realm": "e-gov-portal",
  "displayName": "E-Government Portal",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "id": "a1b2c3d4-0001-4000-8000-000000000001",
        "name": "applicant",
        "description": "Can submit scholarship applications",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0002-4000-8000-000000000002",
        "name": "officer",
        "description": "Can review and manage applications",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0003-4000-8000-000000000003",
        "name": "admin",
        "description": "Full access",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0004-4000-8000-000000000004",
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0005-4000-8000-000000000005",
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0006-4000-8000-000000000006",
        "name": "default-roles-e-gov-portal",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["offline_access", "uma_authorization"],
          "client": {}
        },
        "clientRole": false,
        "containerId": "e-gov-portal"
      },
      {
        "id": "a1b2c3d4-0007-4000-8000-000000000007",
        "name": "scholarship_level_admin",
        "description": "Admin for scholarship rules/levels",
        "composite": false,
        "clientRole": false,
        "containerId": "e-gov-portal"
      }
    ],
    "client": {}
  },
  "clients": [
    {
      "id": "b2c3d4e5-0001-4000-8000-000000000001",
      "clientId": "scholarship-api",
      "name": "Scholarship API (NestJS)",
      "description": "Backend API - validates JWT from Keycloak",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "scholarship-api-secret-change-in-production",
      "redirectUris": ["http://localhost:3000/*", "http://localhost:*/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:*", "+"],
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "protocol": "openid-connect",
      "attributes": {
        "use.refresh.tokens": "true"
      }
    },
    {
      "id": "b2c3d4e5-0002-4000-8000-000000000002",
      "clientId": "scholarship-frontend",
      "name": "Scholarship Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:4200/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:4200", "+"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "protocol": "openid-connect"
    }
  ],
  "defaultDefaultClientScopes": ["role_list", "profile", "email", "web-origins"],
  "defaultOptionalClientScopes": ["offline_access", "address", "phone", "microprofile-jwt"],
  "browserFlow": "browser",
  "registrationFlow": "registration",
  "directGrantFlow": "direct grant",
  "resetCredentialsFlow": "reset credentials",
  "clientAuthenticationFlow": "clients",
  "dockerAuthenticationFlow": "docker auth"
}
